<meta charset="UTF-8" />

<title>Inscripcion hackatón EduTech</title>

<h1>Formulario de inscripcion hackaton EduTech</h1>
    <form id="InscriptionForm">
      <label for="FullName">Apellido y Nombre:</label>
      <br><input
        type="text"
        id="FullName"
        name="FullName"
        required
        placeholder="Ej: Garcia, Gustavo"
      /><br /><br />

      <label for="DocumentNumber">DNI:</label>
      <br><input
        type="text"
        id="DocumentNumber"
        name="DocumentNumber"
        required
        placeholder="Ej: 12345678"
      /><br /><br />


      <label for="Email">Correo Electronico:</label>
      <br><input
        type="email"
        id="Email"
        name="Email"
        required
        placeholder="Ej: tuemail@gmail.com"
      /><br /><br />
      <label for="Telephone">Telefono:</label>
      <br><input
        type="tel"
        id="Telephone"
        name="Telephone"
        required
        placeholder="Ej: 2613555444"
      /><br /><br />
      <button type="submit">Enviar</button>
    </form>