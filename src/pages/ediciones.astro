---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import PreviousEditions from '../components/PreviousEditions.astro';
---

<Layout title="Ediciones Anteriores | HEM2026">
  <main class="page-content">
    <div class="container">
      <h1 class="text-center page-title">Historia del Hackathon</h1>
    </div>
    <PreviousEditions />
  </main>
</Layout>

<style>
  .page-content {
    padding-top: calc(var(--nav-h) + 2rem);
    min-height: calc(100vh - var(--nav-h));
  }
  
  .page-title {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 2.5rem;
  }
</style>
