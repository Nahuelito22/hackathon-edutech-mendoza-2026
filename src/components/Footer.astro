---
// src/components/Footer.astro
---

<footer class="site-footer">
    <div class="container">
        <div class="ftr-top">
            <div class="ftr-brand">
                <a href="#inicio" class="nav-logo" style="margin-bottom: 0.5rem;">
                    <span class="logo-m">
                        <svg viewBox="0 0 40 40" fill="none">
                            <rect x="4" y="4" width="32" height="32" rx="6" stroke="var(--c1)" stroke-width="2.5"/>
                            <path d="M13 12h14M13 20h10M13 28h14" stroke="var(--c1)" stroke-width="2.5" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="logo-t">
                        <span class="logo-main">Edu<span class="logo-hl">Tech</span></span>
                        <span class="logo-sub">Mendoza 2026</span>
                    </span>
                </a>
                <p>Hackathon EduTech Mendoza 2026 &ndash; 2da edición. Organizada por el IES 9-023 de Maipú y el IES Tomás Alva Edison.</p>
            </div>
            <div class="ftr-links">
                <div class="ftr-col">
                    <h4>Evento</h4>
                    <ul>
                        <li><a href="#acerca">Acerca</a></li>
                        <li><a href="#cronograma">Cronograma</a></li>
                        <li><a href="#ediciones">Ediciones anteriores</a></li>
                        <li><a href="#faq">Preguntas frecuentes</a></li>
                    </ul>
                </div>
                <div class="ftr-col">
                    <h4>Participá</h4>
                    <ul>
                        <li><a href="#registro">Inscripción</a></li>
                        <li><a href="#">Bases y Condiciones</a></li>
                        <li><a href="#">Contacto</a></li>
                    </ul>
                </div>
                <div class="ftr-col">
                    <h4>Organizan</h4>
                    <ul>
                        <li><a href="#">IES N°9-023 Maipú</a></li>
                        <li><a href="#">IES Tomás Alva Edison</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="ftr-bot">
            <span class="ftr-copy">&copy; 2026 Hackathon EduTech Mendoza. Todos los derechos reservados.</span>
            <span class="ftr-copy">Diseñado con fines educativos</span>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        padding: 6rem 0 2.5rem;
        border-top: 1px solid var(--brd);
        position: relative;
        z-index: 1;
        transition: border-color var(--t-theme);
        background: var(--bg-1);
    }

    .ftr-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 3rem;
        margin-bottom: 3rem;
    }

    .ftr-brand {
        max-width: 300px;
    }

    .ftr-brand p {
        font-size: 0.875rem;
        margin-top: 1rem;
        color: var(--txt-2);
        line-height: 1.6;
    }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: var(--txt-1);
    }

    .logo-m {
        width: 38px;
        height: 38px;
        border-radius: var(--r-sm);
        background: rgba(var(--c1r), 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background var(--t-theme);
    }

    .logo-m svg {
        width: 22px;
        height: 22px;
    }

    .logo-t {
        display: flex;
        flex-direction: column;
        line-height: 1;
    }

    .logo-main {
        font-family: var(--font-display);
        font-size: 1.4rem;
        letter-spacing: 0.05em;
    }

    .logo-hl {
        color: var(--c1);
        transition: color var(--t-theme);
    }

    .logo-sub {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--txt-m);
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    .ftr-links {
        display: flex;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .ftr-col h4 {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--txt-m);
        margin-bottom: 1rem;
    }

    .ftr-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ftr-col li {
        margin-bottom: 0.5rem;
    }

    .ftr-col a {
        font-size: 0.875rem;
        color: var(--txt-2);
        transition: color var(--t-fast);
        text-decoration: none;
    }

    .ftr-col a:hover {
        color: var(--c1);
    }

    .ftr-bot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
        border-top: 1px solid var(--brd-s);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .ftr-copy {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--txt-m);
        letter-spacing: 0.05em;
    }

    @media (max-width: 767px) {
        .ftr-top {
            flex-direction: column;
        }
        .ftr-bot {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
