---
// src/components/Footer.astro
---

<footer class="site-footer">
    <div class="container">
        <div class="ftr-top">
            <div class="ftr-brand">
                <a href="#inicio" class="nav-logo" style="margin-bottom: 0.5rem;">
                    <img src="/img/brand/MARCA_SIMPLE_NEGRO_SIN_FONDO.png" alt="Hackathon EduTech" class="brand-logo" />
                </a>
                <p>HACKATHON EDUTECH 2026 - Segunda Edición. Organizada por el IES 9-023 de Maipú y el IES Tomás Alva Edison.</p>
            </div>
            <div class="ftr-links">
                <div class="ftr-col">
                    <h4>Evento</h4>
                    <ul>
                        <li><a href="#acerca">Acerca</a></li>
                        <li><a href="#cronograma">Cronograma</a></li>
                        <li><a href="#ediciones">Ediciones anteriores</a></li>
                        <li><a href="#faq">Preguntas frecuentes</a></li>
                    </ul>
                </div>
                <div class="ftr-col">
                    <h4>Participá</h4>
                    <ul>
                        <li><a href="#registro">Inscripción</a></li>
                        <li><a href="#">Bases y Condiciones</a></li>
                        <li><a href="#">Contacto</a></li>
                    </ul>
                </div>
                <div class="ftr-col">
                    <h4>Organizan</h4>
                    <ul>
                        <li><a href="https://ies9023-infd.mendoza.edu.ar/sitio/" target="_blank" rel="noopener noreferrer">IES N°9-023 Maipú</a></li>
                        <li><a href="https://superior.fundacionedison.org.ar/" target="_blank" rel="noopener noreferrer">IES Tomás Alva Edison</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="ftr-bot">
            <span class="ftr-copy">&copy; 2026 HACKATHON EDUTECH. Todos los derechos reservados.</span>
            <span class="ftr-copy">Diseñado con fines educativos</span>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        padding: 6rem 0 2.5rem;
        border-top: 1px solid var(--brd);
        position: relative;
        z-index: 1;
        transition: border-color var(--t-theme);
        background: var(--bg-1);
    }

    .ftr-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 3rem;
        margin-bottom: 3rem;
    }

    .ftr-brand {
        max-width: 300px;
    }

    .ftr-brand p {
        font-size: 0.875rem;
        margin-top: 1rem;
        color: var(--txt-2);
        line-height: 1.6;
    }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: var(--txt-1);
    }

    .brand-logo {
        height: 32px;
        width: auto;
        transition: filter var(--t-theme);
    }

    :global([data-theme="brand-dark"]) .brand-logo {
        filter: invert(1) brightness(2);
    }

    .ftr-links {
        display: flex;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .ftr-col h4 {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--txt-m);
        margin-bottom: 1rem;
    }

    .ftr-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ftr-col li {
        margin-bottom: 0.5rem;
    }

    .ftr-col a {
        font-size: 0.875rem;
        color: var(--txt-2);
        transition: color var(--t-fast);
        text-decoration: none;
    }

    .ftr-col a:hover {
        color: var(--c1);
    }

    .ftr-bot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
        border-top: 1px solid var(--brd-s);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .ftr-copy {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--txt-m);
        letter-spacing: 0.05em;
    }

    @media (max-width: 767px) {
        .ftr-top {
            flex-direction: column;
        }
        .ftr-bot {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
